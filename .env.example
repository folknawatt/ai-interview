# ============================================
# API Keys (Required)
# ============================================
GOOGLE_API_KEY=your_gemini_api_key_here

# ============================================
# Server Configuration
# ============================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
# Domain used for generating public links (e.g. for Audio files)
SERVER_URL=http://localhost:8000

# ============================================
# Database Configuration
# ============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_interview

# ============================================
# AI & TTS Configuration
# ============================================
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.2

TTS_PROVIDER=vachana
TTS_VACHANA_VOICE=th_f_1

# ============================================
# Security & Auth
# ============================================
# !IMPORTANT: Change these in production
JWT_SECRET_KEY=change-this-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

ADMIN_DEFAULT_EMAIL=admin@ai-interview.com
ADMIN_DEFAULT_PASSWORD=change-me-in-production

# ============================================
# CORS & Cookies
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

COOKIE_SECURE=False
COOKIE_SAMESITE=lax

# ============================================
# Google Cloud Secret Manager (Optional)
# ============================================
# Uncomment and fill these to load secrets from GCP
# CONNECTION=your_connection
# SECRET_ID=your_secret_id
# PROJECT_NUMBER=your_project_number