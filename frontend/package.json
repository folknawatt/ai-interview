        "@vueuse/nuxt": "13.2.0",
        "axios": "^1.13.2",
        "chart.js": "^4.5.1",
        "nuxt": "^4.2.1",
        "pinia": "^3.0.4",
        "typescript": "^5.9.3",
        "vue": "^3.5.25",
        "vue-chartjs": "^5.3.3",
        "vue-router": "^4.6.3",
        "zod": "^3.24.4"
    },
    "devDependencies": {
        "@nuxtjs/eslint-config-typescript": "^12.1.0",
