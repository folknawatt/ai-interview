# ============================================
# API Keys
# ============================================
# Google Gemini API Key (Required)
GOOGLE_API_KEY=your_gemini_api_key_here

# ============================================
# Server Configuration
# ============================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ============================================
# Storage Configuration
# ============================================
# Path to the questions database JSON file
# Optional: Defaults to backend/app/config/questions_db.json
# QUESTIONS_FILE_PATH=app/config/questions_db.json

# Directory for temporary file storage
# This should match the storage/temp directory in your project
# TEMP_STORAGE_DIR=storage/temp

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
# Development: http://localhost:3000
# Production: https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ============================================
# AI Configuration
# ============================================
# Gemini model to use
GEMINI_MODEL=gemini-2.5-flash
# Temperature for AI responses (0.0-1.0)
GEMINI_TEMPERATURE=0.2
